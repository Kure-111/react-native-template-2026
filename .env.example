# 環境変数のサンプルファイル
# このファイルを .env にコピーして、実際の値を設定してください

# Supabase設定
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Web Push / Edge Function設定
# 本番では Supabase Project Secrets 側にも同名キーを設定してください
WEB_PUSH_VAPID_PUBLIC_KEY=your-vapid-public-key
WEB_PUSH_VAPID_PRIVATE_KEY=your-vapid-private-key
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
INTERNAL_NOTIFY_TOKEN=your-internal-notify-token

# Google Spreadsheet設定
# スプレッドシートを「リンクを知っている全員が閲覧可能」に設定してください

# 当日部員シフト用スプレッドシート
EXPO_PUBLIC_SHIFT_SPREADSHEET_ID=your-shift-spreadsheet-id

# 祭り開催期間（YYYY-MM-DD形式）
EXPO_PUBLIC_FESTIVAL_START_DATE=2026-11-01
EXPO_PUBLIC_FESTIVAL_END_DATE=2026-11-05

# 将来的に他のスプレッドシートを追加する場合はここに追記
# 例: EXPO_PUBLIC_MEMBER_SPREADSHEET_ID=your-member-spreadsheet-id

# OpenWeatherMap API（Item10 実長システム用）
EXPO_PUBLIC_OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# その他の環境変数
# 必要に応じて追加してください
